{
  "theme": "One Dark",
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "buffer_font_family": "JetBrains Mono",

  "vim_mode": true,
  "relative_line_numbers": true,
  "scroll_beyond_last_line": 0.2,

  "autosave": "on_focus_change",
  "format_on_save": true,

  "tab_size": 2,
  "hard_tabs": false,
  "trim_trailing_whitespace_on_save": true,
  "insert_final_newline_on_save": true,

  "inline_diagnostics": true,
  "diagnostics": {
    "show_warnings": true,
    "show_errors": true
  },

  "git": {
    "inline_blame": false,
    "gutter_icons": true
  },

  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },

  "assistant": {
    "enabled": false
  },

  "languages": {
    "TypeScript": {
      "language_servers": ["typescript-language-server"],
      "format_on_save": true
    },
    "JavaScript": {
      "language_servers": ["typescript-language-server"]
    },
    "Rust": {
      "language_servers": ["rust-analyzer"],
      "format_on_save": true
    },
    "Python": {
      "language_servers": ["mypy"],
      "format_on_save": true
    }
  }
}

