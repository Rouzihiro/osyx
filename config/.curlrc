# always show errors
show-error

# fail on http errors (4xx, 5xx)
fail-with-body

# follow redirects safely
location
max-redirs = 5

# timeouts to avoid hanging forever
connect-timeout = 10
max-time = 60

# retry transient failures
retry = 3
retry-delay = 1
retry-max-time = 30
retry-connrefused

# prefer ipv4 unless explicitly overridden
ipv4

# sane tls defaults
proto = https
proto-redir = https
tlsv1.2

# verify tls properly
ssl-reqd

# better compression
compressed

# don’t dump binary junk to terminal
no-buffer

# reasonable user agent
user-agent = "curl/ops"

# progress bar for interactive use
progress-bar

# keep headers readable when debugging
header = Accept: */*
header = Connection: keep-alive


# keep long-lived connections alive through NATs / tunnels
tcp-keepalive-time = 60

