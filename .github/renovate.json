{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separatePatchReleases"
  ],

  "timezone": "Europe/London",
  "schedule": ["before 6am on Monday"],

  "labels": ["renovate"],
  "assignees": ["rccyx"],

  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "rebaseWhen": "conflicted",

  "commitMessagePrefix": "chore(deps):",

  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },

  "managers": {
    "submodules": {
      "enabled": false
    }
  },

  "packageRules": [
    {
      "description": "GitHub Actions — group all, automerge patch/minor",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "automerge": true,
      "automergeType": "pr",
      "matchUpdateTypes": ["minor", "patch", "digest"]
    },
    {
      "description": "pre-commit hooks — group all",
      "matchManagers": ["pre-commit"],
      "groupName": "pre-commit",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Rust crates — group patch, separate minor/major",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["patch"],
      "groupName": "cargo-patch",
      "automerge": true
    },
    {
      "description": "npm/pnpm — automerge non-breaking",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "npm-non-breaking",
      "automerge": true
    },
    {
      "description": "pip — group all",
      "matchManagers": ["pip_requirements", "pip-compile", "pipenv"],
      "groupName": "pip"
    },
    {
      "description": "Nix — group all",
      "matchManagers": ["nix"],
      "groupName": "nix"
    },
    {
      "description": "Major bumps — never automerge, always require review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["renovate", "major"]
    }
  ],

  "ignorePaths": [
    ".exported/**",
    ".gnupg/**",
    ".ssh/**",
    ".wallpapers/**",
    ".icons/**",
    ".themes/**",
    ".terminfo/**",
    "dircolors/**",
    ".local/share/fonts/**",
    "personal/**",
    "vpn/**",
    ".2fa/**",
    ".aws/**"
  ]
}
