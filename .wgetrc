# robustness on bad networks
timeout = 30
connect_timeout = 10
read_timeout = 30
dns_timeout = 10
tries = 10
retry_connrefused = on
wait_retry = 5
dns_cache = on

# resumable downloads + avoid re-downloading unchanged files
continue = on
timestamping = on
use_server_timestamps = on

# tls safety
check_certificate = on
secure_protocol = auto

# sane naming behavior
content_disposition = on
restrict_file_names = unix

# output
progress = bar
verbose = off
server_response = off

# recursion etiquette
robots = on
https_only = off
span_hosts = off

# proxy behavior
use_proxy = on
no_proxy = localhost,127.0.0.1,::1

# optional: if ipv6 is broken on this network, uncomment one of these
# inet4_only = on
# prefer_family = IPv4

