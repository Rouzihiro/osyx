* {
  font-family: "JetBrainsMono Nerd Font", "Inter", sans-serif;
  font-size: 15px;
  transition: all 0.2s ease-in-out;
}

window {
  margin: 0px;
  border-radius: 20px;
  border: 2px solid rgba({{ wofi_border_rgb }}, 0.4);
  /* Premium Dark/Blackish Gray Universal Background */
  background-color: rgba(18, 18, 22, 0.85);
  box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.5);
}

#outer-box {
  margin: 0px;
  padding: 24px;
  background: transparent;
}

#input {
  margin: 0px 0px 20px 0px;
  padding: 16px 20px;
  border-radius: 12px;
  border: 1px solid rgba({{ wofi_border_rgb }}, 0.3);
  /* Slightly lighter dark background for the search bar */
  background-color: rgba(30, 30, 35, 0.6);
  color: #{{ wofi_border }};
  caret-color: #{{ wofi_border }};
  font-size: 16px;
  font-weight: 500;
  box-shadow: inset 0px 2px 4px rgba(0, 0, 0, 0.2);
}

#input:focus {
  border: 1px solid rgba({{ wofi_border_rgb }}, 0.8);
  box-shadow: 0px 0px 15px rgba({{ wofi_border_rgb }}, 0.3), inset 0px 2px 4px rgba(0, 0, 0, 0.2);
}

#scroll {
  margin: 0px;
}

#inner-box {
  background: transparent;
  padding: 0px;
}

#entry {
  margin: 4px 0px;
  padding: 12px 16px;
  border-radius: 10px;
  background-color: transparent;
  border: 1px solid transparent;
}

#img {
  margin-right: 14px;
  background: transparent;
}

#text {
  /* Default text color is a soft grey so it isn't overwhelmingly themed */
  color: #D8DEE9;
  font-weight: 500;
}

#entry:selected {
  /* Use the theme's highlight color for the background, but keep it translucent */
  background-color: rgba({{ wofi_border_rgb }}, 0.25);
  border: 1px solid rgba({{ wofi_border_rgb }}, 0.5);
  box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.2);
}

#entry:selected #text {
  /* When selected, text becomes the bright theme color */
  color: #{{ wofi_border }};
  font-weight: 600;
}

* > b, #text b {
  /* Highlighted matched characters in search */
  color: #{{ wofi_border }};
  font-weight: 800;
}

/* Scrollbar styling for a modern floating look */
#scroll trough {
  background: transparent;
}
#scroll slider {
  background-color: rgba({{ wofi_border_rgb }}, 0.3);
  border-radius: 10px;
  min-height: 30px;
}
