# ===================================================================
# Terminal filters
# ===================================================================
COLORTERM ?*
TERM *color*
TERM *direct*
TERM xterm*
TERM screen*
TERM tmux*
TERM rxvt*
TERM st
TERM linux
TERM konsole
TERM kitty
TERM foot
TERM gnome
TERM wezterm

# ===================================================================
# Basic file attributes
# ===================================================================

RESET 0


DIR 01;38;2;{{ dircolors_dir_ansi }}
LINK 01;38;2;{{ dircolors_link_ansi }}
MULTIHARDLINK 00
FIFO 48;2;{{ dircolors_bg_ansi }};38;2;{{ dircolors_dir_ansi }}
SOCK 01;38;2;{{ dircolors_fg_ansi }}
DOOR 01;38;2;{{ dircolors_fg_ansi }}
BLK  48;2;{{ dircolors_bg_ansi }};38;2;{{ dircolors_link_ansi }};01
CHR  48;2;{{ dircolors_bg_ansi }};38;2;{{ dircolors_link_ansi }};01
ORPHAN 48;2;{{ dircolors_bg_ansi }};38;2;{{ dircolors_orphan_ansi }};01
MISSING 00
SETUID 38;2;{{ dircolors_fg_ansi }};48;2;{{ dircolors_orphan_ansi }}
SETGID 38;2;{{ dircolors_bg_ansi }};48;2;{{ dircolors_dir_ansi }}
CAPABILITY 00
STICKY_OTHER_WRITABLE 38;2;{{ dircolors_bg_ansi }};48;2;{{ dircolors_link_ansi }}
OTHER_WRITABLE       38;2;{{ dircolors_fg_ansi }};48;2;{{ dircolors_link_ansi }}
STICKY               38;2;{{ dircolors_fg_ansi }};48;2;{{ dircolors_dir_ansi }}
EXEC 01;38;2;{{ dircolors_exec_ansi }}

