#!/usr/bin/env bash
[ -n "${BASH_VERSION:-}" ] || exec bash "$0" "$@"
set -Eeuo pipefail

VERSION="0.2.0"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd -P)"

XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"

STATE_DIR_DEFAULT="$XDG_STATE_HOME/osyx-bootstrap"
CACHE_DIR_DEFAULT="$XDG_CACHE_HOME/osyx-bootstrap"
LOG_DIR_DEFAULT="$CACHE_DIR_DEFAULT/logs"
STATE_FILE_DEFAULT="$STATE_DIR_DEFAULT/state.env"

PROFILE_DEFAULT="desktop"
PREFIX_DEFAULT="/usr/local"
LOCALE_DEFAULT="fr_FR.UTF-8"
TZ_DEFAULT="Europe/Zurich"

STATE_DIR="$STATE_DIR_DEFAULT"
CACHE_DIR="$CACHE_DIR_DEFAULT"
LOG_DIR="$LOG_DIR_DEFAULT"
STATE_FILE="$STATE_FILE_DEFAULT"

HYPRBUILD_REL="hyprtryx/hyprtryx"
BOOTSTRAP_REL="provisioning/bootstrap"

# shellcheck source=/dev/null
source "$SCRIPT_DIR/bootstrap.d/core.sh"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/bootstrap.d/state.sh"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/bootstrap.d/privilege.sh"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/bootstrap.d/apt.sh"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/bootstrap.d/tooling.sh"

CMD="${1:-}"
shift || true

main "$@"
