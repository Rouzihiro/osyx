[init]
    defaultBranch = main

[merge]
    tool = nvimdiff

[mergetool "nvimdiff"]
    # 3-way vertical merge layout in nvim
    cmd = nvim -d "$LOCAL" "$REMOTE" "$MERGED" -c "wincmd J"
    keepBackup = false
    prompt = false

[blame]
    # skip mass-refactors in blame history
    ignoreRevsFile = .git-blame-ignore-revs

[diff]
    tool = nvimdiff

[difftool "nvimdiff"]
    cmd = nvim -d "$LOCAL" "$REMOTE"
    prompt = false

[core]
    editor = nvim

[pull]
    # linear history maintenance
    rebase = true

[push]
    # upstream branch auto-tracking
    default = current

[rebase]
    # workflow automation for fixups/stashing
    autosquash = true
    autostash = true

[fetch]
    # prune stale remote refs
    prune = true
    pruneTags = true
