#!/bin/bash
set -euo pipefail

GO_VERSION=1.22.5
ARCH=linux-amd64
TARBALL="go${GO_VERSION}.${ARCH}.tar.gz"

curl -fsSL -o "$TARBALL" "https://golang.org/dl/${TARBALL}"

# Remove any old Go in /usr/local and install fresh
sudo rm -rf /usr/local/go
sudo tar -C /usr/local -xzf "$TARBALL"
rm -f "$TARBALL"

# Add Go to PATH and set GOPATH for the user
for rc in "$HOME/.zshrc" "$HOME/.profile"; do
	if ! grep -q "/usr/local/go/bin" "$rc" 2>/dev/null; then
		echo '# go' >> "$rc"
		echo 'export PATH="$PATH:/usr/local/go/bin"' >> "$rc"
		echo 'export GOPATH="$HOME/go"' >> "$rc"
		echo 'export PATH="$PATH:$GOPATH/bin"' >> "$rc"
	fi
done
