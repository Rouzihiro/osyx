#!/usr/bin/env bash
set -Eeuo pipefail

PNPM_HOME="${PNPM_HOME:-$HOME/.local/share/pnpm}"
PNPM_VERSION="${PNPM_VERSION:-9.15.0}" # Should be updated periodically to stable baseline

mark_start='# >>> osyx:pnpm >>>'
mark_end='# <<< osyx:pnpm <<<'

persist_block() {
  local f="$1"
  mkdir -p "$(dirname "$f")"
  touch "$f"

  if grep -qF "$mark_start" "$f"; then
    return 0
  fi

  {
    echo ""
    echo "$mark_start"
    echo "export PNPM_HOME=\"\$HOME/.local/share/pnpm\""
    echo "case \":\$PATH:\" in"
    echo "  *\":\$PNPM_HOME/bin:\"*) ;;"
    echo "  *) export PATH=\"\$PNPM_HOME/bin:\$PNPM_HOME:\$PATH\" ;;"
    echo "esac"
    echo "$mark_end"
  } >>"$f"
}

# load nvm if present (needed because each installer runs in its own bash process)
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  # shellcheck disable=SC1090
  . "$NVM_DIR/nvm.sh"
  nvm use default >/dev/null 2>&1 || true
fi

command -v node >/dev/null 2>&1 || { echo "[err] node not found (run --with=node first)"; exit 1; }
command -v corepack >/dev/null 2>&1 || { echo "[err] corepack not found"; exit 1; }

corepack enable >/dev/null 2>&1 || true
corepack prepare "pnpm@${PNPM_VERSION}" --activate

export PNPM_HOME
case ":$PATH:" in
  *":$PNPM_HOME/bin:"*) ;;
  *) export PATH="$PNPM_HOME/bin:$PNPM_HOME:$PATH" ;;
esac

persist_block "$HOME/.profile"
persist_block "$HOME/.zshrc"

command -v pnpm >/dev/null 2>&1 || { echo "[err] pnpm still not on PATH"; exit 1; }

pnpm add -g typescript ts-node eslint prettier
