# ===================================================================
# Terminal filters
# ===================================================================
COLORTERM ?*
TERM *color*
TERM *direct*
TERM xterm*
TERM screen*
TERM tmux*
TERM rxvt*
TERM st
TERM linux
TERM konsole
TERM kitty
TERM foot
TERM gnome
TERM wezterm

# ===================================================================
# Basic file attributes
# ===================================================================

RESET 0

DIR 01;38;2;0;170;164
LINK 01;38;2;127;188;179
MULTIHARDLINK 00
FIFO 48;2;0;20;14;38;2;0;170;164
SOCK 01;38;2;142;215;207
DOOR 01;38;2;142;215;207
BLK  48;2;0;20;14;38;2;127;188;179;01
CHR  48;2;0;20;14;38;2;127;188;179;01
ORPHAN 48;2;0;20;14;38;2;255;77;109;01
MISSING 00
SETUID 38;2;142;215;207;48;2;255;77;109
SETGID 38;2;0;20;14;48;2;0;170;164
CAPABILITY 00
STICKY_OTHER_WRITABLE 38;2;0;20;14;48;2;127;188;179
OTHER_WRITABLE       38;2;142;215;207;48;2;127;188;179
STICKY               38;2;142;215;207;48;2;0;170;164
EXEC 01;38;2;1;138;131

