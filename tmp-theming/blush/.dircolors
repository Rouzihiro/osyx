# ===================================================================
# Terminal filters
# ===================================================================
COLORTERM ?*
TERM *color*
TERM *direct*
TERM xterm*
TERM screen*
TERM tmux*
TERM rxvt*
TERM st
TERM linux
TERM konsole
TERM kitty
TERM foot
TERM gnome
TERM wezterm

# ===================================================================
# Basic file attributes
# ===================================================================

RESET 0

DIR 01;38;2;202;147;149
LINK 01;38;2;185;112;116
MULTIHARDLINK 00
FIFO 48;2;18;8;10;38;2;202;147;149
SOCK 01;38;2;202;147;149
DOOR 01;38;2;202;147;149
BLK  48;2;18;8;10;38;2;185;112;116;01
CHR  48;2;18;8;10;38;2;185;112;116;01
ORPHAN 48;2;18;8;10;38;2;207;44;60;01
MISSING 00
SETUID 38;2;202;147;149;48;2;207;44;60
SETGID 38;2;18;8;10;48;2;202;147;149
CAPABILITY 00
STICKY_OTHER_WRITABLE 38;2;18;8;10;48;2;185;112;116
OTHER_WRITABLE       38;2;202;147;149;48;2;185;112;116
STICKY               38;2;202;147;149;48;2;202;147;149
EXEC 01;38;2;202;147;149

